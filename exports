# Default editor
export EDITOR='nvim'

# Prefer US English and use UTF-8 encoding.
export LANG="en_US.UTF-8"
export LC_ALL="en_US.UTF-8"

export PATH="$HOME/.local/bin:$PATH"
export TMPDIR="$HOME/.tmp"

## bat
export BAT_THEME="Catppuccin Mocha"
export MANPAGER="sh -c 'col -bx | bat -l man -p'"

## fzf — ripgrep backend; scoped previews per picker
export FZF_DEFAULT_COMMAND='rg --files --hidden --follow --glob "!.git"'
export FZF_DEFAULT_OPTS='--height 40% --layout=reverse --border'
export FZF_CTRL_T_OPTS='--preview "bat --color=always --line-range :200 {}" --preview-window "right:50%:wrap"'
export FZF_ALT_C_OPTS='--preview "eza --tree --color=always {} | head -50" --preview-window "right:50%:wrap"'
